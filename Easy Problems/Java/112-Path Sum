/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean hasPathSum(TreeNode root, int targetSum) {
        //solved using DFS

        if(root == null) return false;
        //base case

        if(root.left == null && root.right == null)
            return targetSum - root.val == 0;
        /*if leaf node, return t/f depending on the path. If path exists in tree, should
        eventually return true */
        
        targetSum -= root.val;
        /*KEY: if not leaf node, subtract from targetSum until # matches leaf node val (if it exists as a path in the tree) */

        return hasPathSum(root.left, targetSum) || hasPathSum(root.right, targetSum);
        /*to go deeper into each subtree to see if either one has path that leads to target sum */

        /*key is splitting each subtree into its own tree and handling the problem from there */
    }
}