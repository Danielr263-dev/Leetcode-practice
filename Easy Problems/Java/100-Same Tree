/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution{
    //DFS solution
    public boolean isSameTree(TreeNode p, TreeNode q) {

        //base case, if both trees null they're identical
        if(p == null && q == null)
            return true;

        //if only 1 tree null or vals different, trees are diff
        if(p == null || q == null || p.val != q.val)
            return false;
        //recursively check left and right subtrees to see if identical
        return isSameTree(p.left, q.left) && isSameTree(p.right, q.right);
    }

    //DFS w/ stack: REVIEW IT 
    public boolean isSameTree(TreeNode p, TreeNode q)
    {
        Stack<TreeNode[]> stack = new Stack<>();
        stack.push(new TreeNode[]{p,q});

        while(!stack.isEmpty())
        {
            TreeNode[] pair = stack.pop()
            TreeNode a = pair[0];
            TreeNode b = pair[1];

            if(a != null || b != null)
            {
                if(a == null || b == null || a.val != b.val)
                    return false;
                stack.push(new TreeNode[]{a.left, b.left});
                stack.push(new TreeNode[]{a.right, b.right});
            }
        }
        return true;
    }

}